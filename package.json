{
  "name": "pavtibook-backend",
  "version": "1.0.0",
  "description": "Pavtibook - Inventory Management with Billing System Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "npm run local",
    "dev": "npm run local",
    "local": "concurrently \"npm run backend:php\" \"npm run frontend\"",
    "frontend": "vite --host localhost --port 3000",
    "frontend:dist": "serve -s dist -l 3000",
    "backend:php": "php -S localhost:8000 -t backend backend/index.php",
    "db:setup": "php backend/setup_local_db.php",
    "build": "vite build",
    "test": "jest --coverage",
    "migrate-latest": "node migrate.js",
    "migrate-rollback": "node src/database/rollback.js",
    "seed": "node src/database/seeders/index.js",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "inventory",
    "billing",
    "multi-tenant",
    "POS",
    "franchise"
  ],
  "author": "Development Team",
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "framer-motion": "^12.38.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "number-to-words": "^1.2.4",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^6.30.3",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "sequelize": "^6.35.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.9",
    "serve": "^14.2.4",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
