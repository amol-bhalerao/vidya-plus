# ============================================
# SOLARWALA INVENTORY - HOSTINGER DEPLOYMENT
# ============================================
# Upload this file to Hostinger panel or set
# these variables in Environment Variables section
# ============================================

# Application Settings
NODE_ENV=development
APP_NAME=Solarwala Inventory
APP_HOST=localhost
APP_PORT=5000
# NOTE: Don't set APP_PORT - Hostinger auto-assigns via PORT env var
# If needed, set PORT=3000 in Hostinger (or leave empty for auto-assignment)

# JWT Configuration (CHANGE THESE!)
JWT_SECRET=devsecret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Database Configuration
# Request database details from Hostinger or your database provider
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root            # or whatever user you created
DB_PASSWORD=            # root password (empty with XAMPP)
DB_NAME=pavtibook_db  

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_credentials

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS Configuration
# List all frontend domains that will call this API (comma-separated)
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000/api

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
