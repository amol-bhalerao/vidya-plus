# ============================================
# VIDYA+ LOCAL DEVELOPMENT CONFIGURATION
# ============================================
# Update these values as needed for your local
# or server environment.
# ============================================

# Application Settings
NODE_ENV=development
APP_NAME=Vidya Plus
APP_HOST=localhost
APP_PORT=5000
# Adjust the app port only if your local environment needs a different value.

# JWT Configuration (CHANGE THESE!)
JWT_SECRET=devsecret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Database Configuration
# Use your local MySQL credentials or server database details here.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root            # or whatever user you created
DB_PASSWORD=            # root password (empty with XAMPP)
DB_NAME=pavtibook_db  

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_credentials

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS Configuration
# List all frontend domains that will call this API (comma-separated)
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000/api

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
